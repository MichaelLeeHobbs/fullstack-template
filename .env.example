# ===================
# Application
# ===================
NODE_ENV=development
PORT=3000

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# ===================
# Database
# ===================
DATABASE_URL=postgresql://app:app_dev@localhost:5432/app
# Enable SSL for production database connections
DATABASE_SSL=false

# ===================
# Authentication
# ===================
JWT_SECRET=your-super-secret-key-change-in-production-minimum-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key for secrets at rest (TOTP secrets, etc.)
# Optional — falls back to JWT_SECRET if not set
# In production, use a separate 32+ character key
# ENCRYPTION_KEY=your-encryption-key-minimum-32-characters-long

# Trust proxy — set to 'true' or '1' behind a reverse proxy (nginx, ALB, etc.)
# Accepts: 'false', 'true', '1', 'loopback', or specific IPs
TRUST_PROXY=false

# ===================
# Logging
# ===================
LOG_LEVEL=debug

# ===================
# S3 / MinIO
# ===================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=app-assets
S3_REGION=us-east-1

# ===================
# Email Configuration
# ===================
# Provider: mock (default), smtp, ses
EMAIL_PROVIDER=mock

# From address for all emails
# EMAIL_FROM=noreply@yourdomain.com

# --- SMTP Configuration (for EMAIL_PROVIDER=smtp) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# SMTP_SECURE=true

# --- AWS SES Configuration (for EMAIL_PROVIDER=ses) ---
# AWS_SES_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ===================
# NOTE: Feature Flags
# ===================
# Feature flags are stored in the database (system_settings table)
# and can be managed via Admin UI at /admin/settings
# Run `pnpm db:seed` to populate default settings


