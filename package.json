{
  "name": "fullstack-template",
  "private": true,
  "scripts": {
    "docker:up": "docker compose -f docker-compose.yml up -d --build",
    "docker:down": "docker compose -f docker-compose.yml down",
    "docker:reset": "docker compose -f docker-compose.yml down -v",
    "docker:logs": "docker compose -f docker-compose.yml logs -f",
    "docker:db:psql": "docker exec -it app-db psql -U app -d app",
    "dev": "pnpm run --parallel dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm run -r build",
    "lint": "eslint apps packages --ignore-pattern 'dist/**'",
    "test": "pnpm run -r test",
    "test:api": "pnpm --filter api test",
    "test:web": "pnpm --filter web test",
    "test:coverage": "pnpm run -r test:coverage",
    "db:generate": "pnpm run build && pnpm --filter api db:generate",
    "db:migrate": "pnpm run build && pnpm --filter api db:migrate",
    "db:studio": "pnpm run build && pnpm --filter api db:studio",
    "db:seed": "pnpm --filter api db:seed",
    "db:scripts": "pnpm --filter api db:scripts",
    "clean": "pnpm run -r clean"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@typescript-eslint/eslint-plugin": "8.18.2",
    "@typescript-eslint/parser": "8.18.2",
    "eslint": "9.17.0",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.1",
  "pnpm": {
    "overrides": {
      "vitest@>=2.0.0 <2.1.9": ">=2.1.9 <3.0.0",
      "vite@>=6.0.0 <=6.4.0": ">=6.4.1 <7.0.0",
      "@eslint/plugin-kit@<0.3.4": ">=0.3.4",
      "qs@<6.14.1": ">=6.14.1",
      "@remix-run/router@<=1.23.1": ">=1.23.2",
      "react-router@>=6.0.0 <7.0.0": "6.28.2",
      "tar@<7.5.7": ">=7.5.7",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "fast-xml-parser@>=4.3.6 <=5.3.3": ">=5.3.4",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1"
    }
  }
}
